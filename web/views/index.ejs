<%- include('header', { title: 'Submit', user }) %>

<div class="d-flex align-items-center gap-3 mb-4">
  <img src="/images/sorting-emails.png" alt="Dog sorting bounce emails" width="100" class="d-none d-md-block" />
  <div>
    <h1 class="h3 mb-1">SMTP Bounce Classifier</h1>
    <p class="text-body-secondary mb-0">
      Help improve the <a href="https://github.com/postalsys/bounce-classifier" target="_blank">bounce-classifier</a>
      by submitting labeled SMTP bounce messages.
      <span id="model-badge"></span>
    </p>
  </div>
</div>

<div id="status" class="alert alert-danger d-none" role="alert"></div>
<div id="success" class="alert alert-success d-none" role="alert"></div>

<div class="mb-3">
  <label for="message" class="form-label">SMTP bounce/error message</label>
  <textarea id="message" class="form-control font-monospace" rows="5" placeholder="e.g., 550 5.1.1 The email account that you tried to reach does not exist."></textarea>
</div>

<div class="d-flex gap-2 mb-3">
  <button id="classify-btn" class="btn btn-outline-secondary" type="button">
    <i class="bi bi-search"></i> Test Classification
  </button>
</div>

<div id="result" class="card mb-4 d-none">
  <div class="card-body">
    <h2 class="card-title h6 mb-3">Current Model Classification</h2>
    <div id="result-content"></div>
  </div>
</div>

<div class="mb-3">
  <label for="label-select" class="form-label">Your proposed label</label>
  <select id="label-select" class="form-select">
    <option value="">-- Select a category --</option>
  </select>
</div>

<div class="d-flex gap-2 mb-4">
  <% if (user) { %>
    <button id="submit-btn" class="btn btn-primary" type="button" disabled>
      <i class="bi bi-send"></i> Submit Proposal
    </button>
  <% } else { %>
    <a href="/auth/github" class="btn btn-dark">
      <i class="bi bi-github"></i> Login with GitHub to Submit
    </a>
  <% } %>
</div>

<hr class="my-4" />

<div class="card mb-4">
  <div class="card-body">
    <h3 class="card-title h6 mb-1">Bulk Upload (CSV)</h3>
    <p class="text-body-secondary small mb-3">
      Upload multiple proposals at once using a CSV file.
      Format: <code>label,message</code> with one entry per line.
      <a href="/labels" class="text-decoration-none"><i class="bi bi-info-circle"></i> View valid labels</a>
      | <a href="/sample.csv" download class="text-decoration-none"><i class="bi bi-download"></i> Download sample CSV</a>
    </p>

    <% if (user) { %>
      <div class="mb-3">
        <input type="file" id="csv-file" class="form-control form-control-sm" accept=".csv,text/csv" />
      </div>
      <div id="csv-preview" class="d-none mb-3">
        <div class="table-responsive" style="max-height:16rem;overflow-y:auto">
          <table class="table table-sm table-bordered small mb-0">
            <thead class="table-light"><tr><th>Row</th><th>Label</th><th>Message</th></tr></thead>
            <tbody id="csv-preview-body"></tbody>
          </table>
        </div>
        <div class="mt-2 d-flex align-items-center gap-2">
          <span id="csv-count" class="text-body-secondary small"></span>
          <button id="csv-upload-btn" class="btn btn-sm btn-primary">
            <i class="bi bi-upload"></i> Upload All
          </button>
        </div>
      </div>
      <div id="csv-status" class="d-none"></div>
    <% } else { %>
      <a href="/auth/github" class="btn btn-dark btn-sm">
        <i class="bi bi-github"></i> Login with GitHub to Upload
      </a>
    <% } %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <h3 class="card-title h6 mb-3">Try these examples</h3>
    <div class="d-flex flex-wrap gap-2">
      <button class="btn btn-sm btn-outline-secondary example-btn" data-message="550 5.1.1 The email account that you tried to reach does not exist.">User Unknown</button>
      <button class="btn btn-sm btn-outline-secondary example-btn" data-message="552 5.2.2 The email account that you tried to reach is over quota.">Mailbox Full</button>
      <button class="btn btn-sm btn-outline-secondary example-btn" data-message="421 4.7.0 Try again later, closing connection.">Greylisting</button>
      <button class="btn btn-sm btn-outline-secondary example-btn" data-message="550 5.7.1 Service unavailable, IP blocked by Spamhaus ZEN">IP Blacklisted</button>
      <button class="btn btn-sm btn-outline-secondary example-btn" data-message="550 5.7.1 Unauthenticated email is not accepted due to domain DMARC policy.">Auth Failure</button>
      <button class="btn btn-sm btn-outline-secondary example-btn" data-message="421 4.7.28 Too many connections from your IP address. Try again in 30 minutes.">Rate Limited</button>
      <button class="btn btn-sm btn-outline-secondary example-btn" data-message="552 5.7.0 Our system detected an illegal attachment on your message.">Virus Detected</button>
    </div>
  </div>
</div>

<%- include('footer') %>
<script src="/app.js"></script>
  </body>
</html>
