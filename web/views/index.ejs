<%- include('header', { title: 'Submit', user }) %>

<h1>SMTP Bounce Classifier</h1>
<p class="subtitle">
  Help improve the <a href="https://github.com/postalsys/bounce-classifier" target="_blank">bounce-classifier</a>
  by submitting labeled SMTP bounce messages.
</p>

<div id="status" class="alert alert-error" style="display:none"></div>
<div id="success" class="alert alert-success" style="display:none"></div>

<div class="form-group">
  <label for="message">SMTP bounce/error message:</label>
  <textarea id="message" placeholder="e.g., 550 5.1.1 The email account that you tried to reach does not exist."></textarea>
</div>

<div class="button-row">
  <button id="classify-btn" class="btn btn-secondary" type="button">Test Classification</button>
</div>

<div id="result" class="result-panel" style="display:none">
  <h2>Current Model Classification</h2>
  <div id="result-content"></div>
</div>

<div class="form-group" style="margin-top:1.5rem">
  <label for="label-select">Your proposed label:</label>
  <select id="label-select">
    <option value="">-- Select a category --</option>
  </select>
</div>

<div class="button-row">
  <% if (user) { %>
    <button id="submit-btn" class="btn btn-primary" type="button" disabled>Submit Proposal</button>
  <% } else { %>
    <a href="/auth/github" class="btn btn-primary">Login with GitHub to Submit</a>
  <% } %>
</div>

<div class="examples">
  <h3>Try these examples:</h3>
  <div class="examples-grid">
    <button class="example-btn" data-message="550 5.1.1 The email account that you tried to reach does not exist.">User Unknown</button>
    <button class="example-btn" data-message="552 5.2.2 The email account that you tried to reach is over quota.">Mailbox Full</button>
    <button class="example-btn" data-message="421 4.7.0 Try again later, closing connection.">Greylisting</button>
    <button class="example-btn" data-message="550 5.7.1 Service unavailable, IP blocked by Spamhaus ZEN">IP Blacklisted</button>
    <button class="example-btn" data-message="550 5.7.1 Unauthenticated email is not accepted due to domain DMARC policy.">Auth Failure</button>
    <button class="example-btn" data-message="421 4.7.28 Too many connections from your IP address. Try again in 30 minutes.">Rate Limited</button>
    <button class="example-btn" data-message="552 5.7.0 Our system detected an illegal attachment on your message.">Virus Detected</button>
  </div>
</div>

<script src="/app.js"></script>

<%- include('footer') %>
