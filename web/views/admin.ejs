<%- include('header', { title: 'Admin', user }) %>

<div class="d-flex align-items-center gap-3 mb-3">
  <img src="/images/tuning-controls.png" alt="Dog at control panel" width="80" class="d-none d-md-block" />
  <h1 class="h3 mb-0">Admin Panel</h1>
</div>

<div id="stats-bar" class="d-flex gap-3 mb-3 small"></div>

<ul class="nav nav-tabs mb-3">
  <li class="nav-item">
    <button class="nav-link active" data-status="pending">Pending</button>
  </li>
  <li class="nav-item">
    <button class="nav-link" data-status="approved">Approved</button>
  </li>
  <li class="nav-item">
    <button class="nav-link" data-status="rejected">Rejected</button>
  </li>
</ul>

<div class="d-flex gap-2 flex-wrap mb-3">
  <button id="bulk-approve-btn" class="btn btn-sm btn-success" disabled>
    <i class="bi bi-check-lg"></i> Approve Selected
  </button>
  <button id="bulk-reject-btn" class="btn btn-sm btn-danger" disabled>
    <i class="bi bi-x-lg"></i> Reject Selected
  </button>
  <button id="export-btn" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-download"></i> Export to JSONL
  </button>
  <button id="retrain-btn" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-arrow-repeat"></i> Retrain Model
  </button>
</div>

<div id="retrain-status" class="alert alert-info d-none" role="alert"></div>

<div class="table-responsive">
  <table class="table table-hover table-sm align-middle">
    <thead class="table-light">
      <tr>
        <th style="width:2rem"><input class="form-check-input" type="checkbox" id="select-all" /></th>
        <th>Message</th>
        <th>Proposed</th>
        <th>Model Says</th>
        <th>Conf.</th>
        <th>Submitted By</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody id="proposals-body"></tbody>
  </table>
</div>

<nav id="pagination-nav" aria-label="Proposals pagination">
  <ul class="pagination pagination-sm justify-content-center" id="pagination"></ul>
</nav>

<script src="/admin.js"></script>

<%- include('footer') %>
